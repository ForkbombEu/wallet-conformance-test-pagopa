            "schema": {
              "type": "number"
            },
            "description": "Maximum number of retry attempts"
          },
          {
            "in": "query",
            "name": "log-level",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Logging level (DEBUG, INFO, WARN, ERROR)"
          },
          {
            "in": "query",
            "name": "log-file",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Path to log file"
          },
          {
            "in": "query",
            "name": "port",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Trust Anchor server port"
          },
          {
            "in": "query",
            "name": "save-credential",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Save the received credential to disk"
          },
          {
            "in": "query",
            "name": "issuance-tests-dir",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Override directory for issuance test specs"
          },
          {
            "in": "query",
            "name": "issuance-certificate-subject",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Override mock issuer's certificate subject"
          },
          {
            "in": "query",
            "name": "presentation-tests-dir",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Override directory for presentation test specs"
          },
          {
            "in": "query",
            "name": "steps-mapping",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Override steps mapping as comma-separated key=value pairs"
          },
          {
            "in": "query",
            "name": "unsafe-tls",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Disable TLS certificate verification"
          },
          {
            "in": "query",
            "name": "external-ta-url",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "URL of an external Trust Anchor"
          },
          {
            "in": "query",
            "name": "external-ta-onboarding-url",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Onboarding URL of an external Trust Anchor"
          },
          {
            "in": "query",
            "name": "tests",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma separated list of test names"
          }
        ],
        "responses": {
          "200": {
            "description": "Command execution result"
          }
        }
      },
      "post": {
        "summary": "Run wct test:issuance with JSON body",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command execution result"
          }
        }
      }
    },
