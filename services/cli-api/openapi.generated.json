{
  "openapi": "3.0.3",
  "info": {
    "title": "WCT CLI REST Wrapper",
    "version": "1.0.0",
    "description": "External REST wrapper around the WCT CLI. Request fields map 1:1 to CLI options."
  },
  "servers": [
    {
      "url": "http://0.0.0.0:3100"
    }
  ],
  "components": {
    "schemas": {
      "RunRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "file-ini": {
            "type": "string",
            "description": "Path to custom INI configuration file"
          },
          "credential-issuer-uri": {
            "type": "string",
            "description": "Override the credential issuer URL"
          },
          "credential-offer-uri": {
            "type": "string",
            "description": "Override the credential offer URL"
          },
          "presentation-authorize-uri": {
            "type": "string",
            "description": "Override the presentation authorize URL"
          },
          "credential-types": {
            "type": "string",
            "description": "Comma-separated list of credential configuration IDs to test"
          },
          "timeout": {
            "type": "number",
            "description": "Network timeout in seconds"
          },
          "max-retries": {
            "type": "number",
            "description": "Maximum number of retry attempts"
          },
          "log-level": {
            "type": "string",
            "description": "Logging level (DEBUG, INFO, WARN, ERROR)"
          },
          "log-file": {
            "type": "string",
            "description": "Path to log file"
          },
          "port": {
            "type": "number",
            "description": "Trust Anchor server port"
          },
          "save-credential": {
            "type": "boolean",
            "description": "Save the received credential to disk"
          },
          "issuance-tests-dir": {
            "type": "string",
            "description": "Override directory for issuance test specs"
          },
          "issuance-certificate-subject": {
            "type": "string",
            "description": "Override mock issuer's certificate subject"
          },
          "presentation-tests-dir": {
            "type": "string",
            "description": "Override directory for presentation test specs"
          },
          "steps-mapping": {
            "type": "string",
            "description": "Override steps mapping as comma-separated key=value pairs"
          },
          "unsafe-tls": {
            "type": "boolean",
            "description": "Disable TLS certificate verification"
          },
          "external-ta-url": {
            "type": "string",
            "description": "URL of an external Trust Anchor"
          },
          "external-ta-onboarding-url": {
            "type": "string",
            "description": "Onboarding URL of an external Trust Anchor"
          },
          "tests": {
            "type": "string",
            "description": "Comma separated list of test names"
          },
          "credential_offer": {
            "type": "string",
            "description": "Compatibility alias for credential-offer-uri, mapped 1:1 to --credential-offer-uri"
          },
          "presentation_request": {
            "type": "string",
            "description": "Compatibility alias for presentation-authorize-uri, mapped 1:1 to --presentation-authorize-uri"
          }
        }
      }
    }
  },
